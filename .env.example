# ── AI Provider ──────────────────────────────────────────────────────────────
OPENCODE_API_KEY=

# ── HTTP Basic Auth ───────────────────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=

# ── Gateway ───────────────────────────────────────────────────────────────────
# Bearer token for gateway auth. Auto-generated and persisted if not set.
OPENCLAW_GATEWAY_TOKEN=
# Comma-separated origins allowed to access the Control UI (e.g. via Cloudflare Tunnel).
GATEWAY_ALLOWED_ORIGINS=

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── Docker API access (optional) ──────────────────────────────────────────────
# Mount /var/run/docker.sock in docker-compose.yml and set DOCKER_HOST to let
# openclaw agents run docker commands. The Docker CLI is auto-installed on first
# start when the socket is detected.
# DOCKER_HOST=unix:///var/run/docker.sock

# ── Port ──────────────────────────────────────────────────────────────────────
PORT=8080
